{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "mockups",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "mockups", "-p", "4400", "--cors", "-c-1"],
      "port": 4400,
      "autoPort": false
    },
    {
      "name": "hytek-install-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "../hytek-install", "run", "dev"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "hytek-planner-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "../hytek-planner", "run", "dev"],
      "port": 3002,
      "autoPort": true
    },
    {
      "name": "v6-viewer",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "scripts", "-p", "4500", "--cors", "-c-1"],
      "port": 4500,
      "autoPort": true
    }
  ]
}

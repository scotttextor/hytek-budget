// ============================================================
// SLIDE 10 — VARIATIONS
// ============================================================
{
  const s = pres.addSlide();
  darkBg(s, BLACK);
  addChip(s, "09 / VARIATIONS");
  addCornerBracket(s);

  s.addText("EVERY CHANGE.", {
    x: 0.6, y: 0.9, w: 9, h: 0.9,
    fontFace: HEADER_FONT, fontSize: 54, color: WHITE,
    align: "left", valign: "middle", charSpacing: 3, margin: 0
  });
  s.addText("TRACKED.", {
    x: 0.6, y: 1.8, w: 9, h: 0.9,
    fontFace: HEADER_FONT, fontSize: 54, color: YELLOW,
    align: "left", valign: "middle", charSpacing: 3, margin: 0
  });

  // State machine — 5 boxes connected
  const states = ["RAISED", "PRICED", "SUBMITTED", "APPROVED", "INVOICED"];
  const sW = 1.55, sH = 0.75, sGap = 0.22;
  const sTotalW = states.length * sW + (states.length - 1) * sGap;
  const sStartX = (W - sTotalW) / 2;
  const sY = 3.15;

  states.forEach((st, i) => {
    const x = sStartX + i * (sW + sGap);
    const isLast = i === states.length - 1;
    s.addShape(pres.shapes.RECTANGLE, {
      x, y: sY, w: sW, h: sH,
      fill: { color: isLast ? YELLOW : GREY_DARK },
      line: { color: YELLOW, width: 1 }
    });
    s.addText(st, {
      x, y: sY, w: sW, h: sH,
      fontFace: HEADER_FONT, fontSize: 14,
      color: isLast ? BLACK : WHITE,
      align: "center", valign: "middle", charSpacing: 3, margin: 0
    });
    if (i < states.length - 1) {
      const arrowX = x + sW + 0.02;
      s.addShape(pres.shapes.RIGHT_TRIANGLE, {
        x: arrowX, y: sY + sH / 2 - 0.06, w: 0.18, h: 0.12,
        rotate: 90, fill: { color: YELLOW }, line: { type: "none" }
      });
    }
  });

  s.addText("No more losing variations between site, office, and invoicing. PO-backed. Audit trail. Nothing slips.", {
    x: 0.6, y: 4.15, w: 9, h: 0.7,
    fontFace: BODY_FONT, fontSize: 14, color: GREY_LIGHT,
    align: "center", valign: "top", margin: 0
  });

  addFooter(s);
}


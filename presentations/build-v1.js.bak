  ];
  const pW = 2.7, pH = 1.25, pGap = 0.25;
  const pTotalW = payers.length * pW + (payers.length - 1) * pGap;
  const pStartX = (W - pTotalW) / 2;
  const pY = 3.05;

  payers.forEach((p, i) => {
    const x = pStartX + i * (pW + pGap);
    s.addShape(pres.shapes.RECTANGLE, { x, y: pY, w: pW, h: pH, fill: { color: GREY_DARK }, line: { color: YELLOW, width: 1 } });
    s.addShape(pres.shapes.RECTANGLE, { x, y: pY, w: pW, h: 0.08, fill: { color: YELLOW }, line: { type: "none" } });
    s.addText(p.who, { x, y: pY + 0.25, w: pW, h: 0.45, fontFace: HEADER_FONT, fontSize: 18, color: WHITE, align: "center", valign: "middle", charSpacing: 4, margin: 0 });
    s.addText(p.note, { x: x + 0.2, y: pY + 0.75, w: pW - 0.4, h: 0.4, fontFace: BODY_FONT, fontSize: 11, color: GREY_LIGHT, align: "center", valign: "middle", margin: 0 });
  });

  s.addText("Rework is logged with a cause. Cost lands on the right cost-centre automatically.", {
    x: 0.6, y: 4.5, w: 9, h: 0.5,
    fontFace: BODY_FONT, fontSize: 13, color: GREY_LIGHT,
    align: "center", valign: "top", margin: 0
  });

  addFooter(s);
}


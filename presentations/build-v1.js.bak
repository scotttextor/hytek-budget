  s.addShape(pres.shapes.ROUNDED_RECTANGLE, { x: phX + phW / 2 - 0.4, y: phY + 0.08, w: 0.8, h: 0.15, fill: { color: "0A0809" }, line: { type: "none" }, rectRadius: 0.05 });

  // Job header bar
  s.addShape(pres.shapes.RECTANGLE, { x: phX + 0.12, y: phY + 0.4, w: phW - 0.24, h: 0.4, fill: { color: YELLOW }, line: { type: "none" } });
  s.addText("SPRINGFIELD TOWER 4B", { x: phX + 0.15, y: phY + 0.4, w: phW - 0.3, h: 0.4, fontFace: HEADER_FONT, fontSize: 9, color: BLACK, align: "center", valign: "middle", charSpacing: 2, margin: 0 });

  // "PROGRESS CLAIM" label
  s.addText("PROGRESS CLAIM", { x: phX + 0.2, y: phY + 0.95, w: phW - 0.4, h: 0.2, fontFace: BODY_FONT, fontSize: 8, color: GREY_MID, align: "left", valign: "middle", charSpacing: 2, margin: 0 });

  // Item pill
  s.addShape(pres.shapes.ROUNDED_RECTANGLE, { x: phX + 0.2, y: phY + 1.2, w: phW - 0.4, h: 0.45, fill: { color: GREY_DARK }, line: { color: YELLOW, width: 0.75 }, rectRadius: 0.08 });
  s.addText("Install — Type A units", { x: phX + 0.3, y: phY + 1.2, w: phW - 0.5, h: 0.45, fontFace: BODY_FONT, fontSize: 10, color: WHITE, align: "left", valign: "middle", margin: 0 });

  // Amount label
  s.addText("AMOUNT", { x: phX + 0.2, y: phY + 1.85, w: phW - 0.4, h: 0.2, fontFace: BODY_FONT, fontSize: 8, color: GREY_MID, align: "left", valign: "middle", charSpacing: 2, margin: 0 });

  // Amount field
  s.addShape(pres.shapes.ROUNDED_RECTANGLE, { x: phX + 0.2, y: phY + 2.1, w: phW - 0.4, h: 0.55, fill: { color: BLACK }, line: { color: YELLOW, width: 1 }, rectRadius: 0.05 });
  s.addText("$ 3,450", { x: phX + 0.3, y: phY + 2.1, w: phW - 0.5, h: 0.55, fontFace: HEADER_FONT, fontSize: 20, color: YELLOW, align: "left", valign: "middle", charSpacing: 2, margin: 0 });

  // Over-budget hint
  s.addText("78% of item budget", { x: phX + 0.2, y: phY + 2.75, w: phW - 0.4, h: 0.2, fontFace: BODY_FONT, fontSize: 8, color: GREY_MID, align: "left", valign: "middle", margin: 0 });

  // SAVE button
  s.addShape(pres.shapes.ROUNDED_RECTANGLE, { x: phX + 0.2, y: phY + 3.4, w: phW - 0.4, h: 0.5, fill: { color: YELLOW }, line: { type: "none" }, rectRadius: 0.08 });
  s.addText("LOG CLAIM", { x: phX + 0.2, y: phY + 3.4, w: phW - 0.4, h: 0.5, fontFace: HEADER_FONT, fontSize: 13, color: BLACK, align: "center", valign: "middle", charSpacing: 4, margin: 0 });


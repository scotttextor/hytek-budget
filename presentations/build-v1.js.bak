  s.addText("PROGRESS\nCLAIM LINE ITEM", { x: 3.6, y: flowY, w: 2.8, h: nodeH, fontFace: HEADER_FONT, fontSize: 14, color: BLACK, align: "center", valign: "middle", charSpacing: 2, margin: 0 });

  // Arrow
  s.addShape(pres.shapes.RIGHT_TRIANGLE, { x: 6.6, y: flowY + nodeH / 2 - 0.12, w: 0.3, h: 0.24, rotate: 90, fill: { color: YELLOW }, line: { type: "none" } });

  // Xero node
  s.addShape(pres.shapes.ROUNDED_RECTANGLE, { x: 7.2, y: flowY, w: 1.8, h: nodeH, fill: { color: GREY_DARK }, line: { color: YELLOW, width: 1 }, rectRadius: 0.08 });
  s.addText("XERO\nDRAFT INVOICE", { x: 7.2, y: flowY, w: 1.8, h: nodeH, fontFace: HEADER_FONT, fontSize: 12, color: WHITE, align: "center", valign: "middle", charSpacing: 2, margin: 0 });

